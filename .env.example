# ── Google Gemini API ────────────────────────────────────────────────────────
# Get your API key from: https://ai.google.dev/
GOOGLE_API_KEY=your_google_api_key_here

# ── Ollama Configuration (Fallback/Alternative LLM) ────────────────────────────
# Base URL for Ollama server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use in Ollama (default: mistral)
# Other options: llama2, neural-chat, dolphin-mixtral, orca-mini, etc.
# Download models with: ollama pull <model_name>
OLLAMA_MODEL=mistral

# ── Database ──────────────────────────────────────────────────────────────────
# Path to DuckDB database (will be created if it doesn't exist)
# Default: duckdb.db
DB_PATH=duckdb.db
